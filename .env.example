# ==================================
# Variables de entorno para Render
# ==================================
# Copia este archivo como .env y completa los valores
# En Render, configura estas variables en el Dashboard > Environment

# Base de datos MySQL (Railway / PlanetScale / TiDB / otro)
DB_HOST=localhost
DB_NAME=caso_practico_backend
DB_USER=root
DB_PASSWORD=

# URL base de la aplicación
# En local (XAMPP): /caso-practico-backend/public/
# En Render (producción): /
BASE_URL=/
